{
  "name": "aio-downloader-ui",
  "version": "1.0.0",
  "description": "Desktop UI for AIO Manga/Webtoon Downloader",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "node scripts/prepare-src.js && vite build && electron-builder",
    "electron:preview": "vite build && cross-env NODE_ENV=production electron ."
  },
  "build": {
    "appId": "com.aio.downloader",
    "productName": "AIO Downloader",
    "files": [
      "dist/**",
      "electron/**"
    ],
    "extraResources": [
      {
        "from": "python-src",
        "to": "python-src",
        "filter": [
          "**/*",
          "!**/__pycache__/**"
        ]
      },
      {
        "from": "build-resources/vcruntime",
        "to": "vcruntime",
        "filter": ["*.dll"]
      }
    ],
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "deleteAppDataOnUninstall": true
    },
    "directories": {
      "output": "release"
    },
    "asar": true,
    "asarUnpack": []
  },
  "dependencies": {
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "lucide-react": "^0.263.1",
    "mupdf": "^1.27.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwind-merge": "^2.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "vite": "^7.3.1",
    "wait-on": "^7.2.0"
  }
}
